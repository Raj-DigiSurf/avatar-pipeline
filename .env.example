# ── Cloudflare R2 ────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=digisurf-avatars
R2_PUBLIC_URL=https://your-r2-public-domain.com

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Dependency paths (after cloning) ─────────────────────────────────
MUSETALK_DIR=./deps/MuseTalk
SADTALKER_DIR=./deps/SadTalker
GFPGAN_MODEL_PATH=./deps/GFPGANv1.4.pth

# ── Pipeline behaviour ────────────────────────────────────────────────
# Lip-sync backend: musetalk | sadtalker
LIPSYNC_BACKEND=musetalk

# Output resolution
OUTPUT_WIDTH=1280
OUTPUT_HEIGHT=720
OUTPUT_FPS=30
